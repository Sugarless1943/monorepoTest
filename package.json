{
  "name": "monorepoTest",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#product": "./product/index.js",
    "#product/*": "./product/*",
    "#scripts/*": "./scripts/*",
    "#tooling/*": "./apps/Sub/tooling/*"
  },
  "scripts": {
    "start": "cd apps/Sub && pnpm dev",
    "test": "pnpm run verify:fast",
    "build": "node ./scripts/build.js",
    "build:sub": "cd apps/Sub && pnpm build",
    "build:groupA": "node ./scripts/build.js group-a",
    "build:groupB": "node ./scripts/build.js group-b",
    "build:groupC": "node ./scripts/build.js group-c",
    "create:page": "node ./scripts/runSubPackageScript.js create:page",
    "export": "node ./scripts/export.js",
    "verify": "node ./internal/repoVerify.js",
    "verify:fast": "node ./internal/repoVerify.js --fast",
    "verify:sub": "node ./scripts/runSubPackageScript.js verify",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=10.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "esbuild": "^0.25.11",
    "eslint": "^10.0.3",
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "**/*.{js,ts,vue,json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
